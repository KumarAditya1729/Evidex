{
  "name": "evidex-evidence-platform",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "./scripts/dev-web.sh",
    "start": "./scripts/run-web.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @evidex/database db:generate",
    "db:migrate": "pnpm --filter @evidex/database db:migrate",
    "db:seed": "pnpm --filter @evidex/database db:seed",
    "contract:compile": "pnpm --filter @evidex/contracts compile",
    "contract:deploy:polygon": "pnpm --filter @evidex/contracts deploy:polygon",
    "contract:test": "pnpm --filter @evidex/contracts test",
    "parachain:setup": "./scripts/setup-parachain.sh",
    "parachain:start": "docker-compose -f docker-compose.parachain.yml up -d",
    "parachain:stop": "docker-compose -f docker-compose.parachain.yml down",
    "parachain:deploy": "./scripts/deploy-parachain.sh",
    "parachain:logs": "docker-compose -f docker-compose.parachain.yml logs -f"
  },
  "devDependencies": {
    "turbo": "^2.1.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": "20.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bufferutil",
      "esbuild",
      "keccak",
      "prisma",
      "secp256k1",
      "unrs-resolver",
      "utf-8-validate"
    ]
  }
}
