# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=replace-with-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evidex?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Pinata / IPFS
PINATA_JWT=replace-with-pinata-jwt

# Polkadot (custom chain - required)
POLKADOT_WS_URL=wss://your-custom-chain-rpc
POLKADOT_MNEMONIC="bottom drive obey lake curtain smoke basket hold race lonely fit walk"
POLKADOT_SCAN_API_URL=https://your-subscan-instance/api/v2/scan/extrinsic
POLKADOT_EXPLORER_BASE_URL=https://your-subscan-instance/extrinsic/
POLKADOT_REMARK_PREFIX=EVIDEX
POLKADOT_USE_PALLET=true
POLKADOT_PALLET_NAME=evidence
POLKADOT_SUBMIT_EXTRINSIC=submitEvidence
POLKADOT_ENABLE_REMARK_FALLBACK=true
SUBSCAN_API_KEY=

# Admin bootstrap
ADMIN_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
