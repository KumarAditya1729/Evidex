{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@evidex/auth": ["packages/auth/src"],
      "@evidex/auth/*": ["packages/auth/src/*"],
      "@evidex/storage": ["packages/storage/src"],
      "@evidex/storage/*": ["packages/storage/src/*"],
      "@evidex/blockchain": ["packages/blockchain/src"],
      "@evidex/blockchain/*": ["packages/blockchain/src/*"],
      "@evidex/database": ["packages/database/src"],
      "@evidex/database/*": ["packages/database/src/*"],
      "@evidex/api": ["packages/api/src"],
      "@evidex/api/*": ["packages/api/src/*"]
    }
  }
}
